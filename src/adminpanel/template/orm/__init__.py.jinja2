from __future__ import annotations

from typing import Any, Callable

from .base import BaseORMAdapter
{% if orm == "sqlalchemy" %}
from .sqlalchemy import SQLAlchemyAdapter
{% elif orm == "tortoise" %}
from .tortoise import TortoiseAdapter
{% endif %}


def resolve_adapter(
    orm: str,
    *,
    transaction: Callable | None = None,
) -> BaseORMAdapter:
{% if orm == "tortoise" %}
    if orm == "tortoise":
        return TortoiseAdapter(transaction=transaction)
{% elif orm == "sqlalchemy" %}
    if orm == "sqlalchemy":
        if transaction is None:
            raise ValueError(
                "transaction is required for sqlalchemy adapter"
            )
        return SQLAlchemyAdapter(transaction=transaction)
{% endif %}
    raise ValueError(f"Unsupported ORM adapter: {orm}")


__all__ = [
    "BaseORMAdapter",
{% if orm == "tortoise" %}
    "TortoiseAdapter",
{% elif orm == "sqlalchemy" %}
    "SQLAlchemyAdapter",
{% endif %}
    "resolve_adapter",
]
