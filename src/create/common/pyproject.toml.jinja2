{%- if package_manager == "poetry" %}
[build-system]
requires = ["poetry-core>=1.9.0"]
build-backend = "poetry.core.masonry.api"

[tool.poetry]
name = "{{ name }}"
version = "0.1.0"
description = "{{ name|capitalize }} backend project with {{ design|upper }} design pattern and {{ 'SQLAlchemy' if orm == 'sqlalchemy' else orm|capitalize }} ORM"
readme = "README.md"
packages = [{ include = "app", from = "src" }]

[tool.poetry.dependencies]
python = "{% if uid == 'uuidv7' %}>=3.13,<4.0{% else %}>=3.11,<4.0{% endif %}"
robyn = { version = ">=0.81.0", extras = ["pydantic"] }
asyncpg = ">=0.29.0"
redis = { version = ">=5.0.4", extras = ["hiredis"] }
{% if broker == "rabbitmq" %}
aio-pika = ">=9.4.3"
{% elif broker == "kafka" %}
aiokafka = ">=0.10.0"
{% endif %}
{% if "mongodb" in nosql %}
pymongo = ">=4.11.0"
{% endif %}
{% if "neo4j" in nosql %}
neo4j = ">=6.2.0"
{% endif %}
{% if worker == "celery" %}
celery = { version = ">=5.5.0", extras = ["redis"] }
{% if worker_backend == "kafka" %}
confluent-kafka = ">=2.3.0"
{% endif %}
{% elif worker == "rq" %}
rq = ">=2.6.0"
{% elif worker == "dramatiq" %}
{% if worker_backend == "rabbitmq" %}
dramatiq = { version = ">=1.18.0", extras = ["rabbitmq"] }
{% else %}
dramatiq = { version = ">=1.18.0", extras = ["redis"] }
{% endif %}
{% if worker_scheduler == "apscheduler" %}
apscheduler = ">=3.11.0"
{% endif %}
{% elif worker == "huey" %}
huey = ">=2.5.0"
{% endif %}
pydantic = { version = ">=2.6.4", extras = ["email"] }
pydantic-settings = ">=2.2.1"
PyJWT = ">=2.8.0"
loguru = ">=0.7.2"
passlib = ">=1.7.4"
bcrypt = "4.0.1"
aiosmtplib = ">=3.0.1"
sqlalchemy = { version = ">=2.0.29", extras = ["asyncio", "mypy"] }
alembic = ">=1.13.2"
tortoise-orm = ">=0.20.0"
aerich = { version = ">=0.9.2", extras = ["toml"] }
{% if uid == "nanoid" %}
python-nanoid = ">=2.0.0"
{% elif uid == "ulid" %}
python-ulid = ">=3.0.0"
{% elif uid == "sparkid" %}
sparkid = ">=1.0.0"
{% endif %}

[tool.poetry.group.dev.dependencies]
black = ">=24.10.0"
isort = ">=6.0.0"
ruff = ">=0.4.1"
pytest = ">=7.4.0"
pytest-cov = ">=4.1.0"
coverage = { version = ">=7.5.0", extras = ["toml"] }
mypy = ">=1.10.0"
flake8 = ">=7.1.0"
aiosqlite = ">=0.21.0"
fakeredis = ">=2.22.4"
py-spy = ">=0.4.1"
{%- else %}
[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ name }}"
version = "0.1.0"
description = "{{ name|capitalize }} backend project with {{ design|upper }} design pattern and {{ 'SQLAlchemy' if orm == 'sqlalchemy' else orm|capitalize }} ORM"
readme = "README.md"
requires-python = "{% if uid == 'uuidv7' %}>=3.13,<4.0{% else %}>=3.11,<4.0{% endif %}"
dependencies = [
  "robyn[pydantic]>=0.81.0",
  "asyncpg>=0.29.0",
  "redis[hiredis]>=5.0.4",
{% if broker == "rabbitmq" %}
  "aio-pika>=9.4.3",
{% elif broker == "kafka" %}
  "aiokafka>=0.10.0",
{% endif %}
{% if "mongodb" in nosql %}
  "pymongo>=4.11.0",
{% endif %}
{% if "neo4j" in nosql %}
  "neo4j>=6.2.0",
{% endif %}
{% if worker == "celery" %}
  "celery[redis]>=5.5.0",
{% if worker_backend == "kafka" %}
  "confluent-kafka>=2.3.0",
{% endif %}
{% elif worker == "rq" %}
  "rq>=2.6.0",
{% elif worker == "dramatiq" %}
{% if worker_backend == "rabbitmq" %}
  "dramatiq[rabbitmq]>=1.18.0",
{% else %}
  "dramatiq[redis]>=1.18.0",
{% endif %}
{% if worker_scheduler == "apscheduler" %}
  "apscheduler>=3.11.0",
{% endif %}
{% elif worker == "huey" %}
  "huey>=2.5.0",
{% endif %}
  "pydantic[email]>=2.6.4",
  "pydantic-settings>=2.2.1",
  "PyJWT>=2.8.0",
  "loguru>=0.7.2",
  "passlib>=1.7.4",
  "bcrypt==4.0.1",
  "aiosmtplib>=3.0.1",
  "SQLAlchemy[asyncio,mypy]>=2.0.29",
  "alembic>=1.13.2",
  "tortoise-orm>=0.20.0",
  "aerich[toml]>=0.9.2",
{% if uid == "nanoid" %}
  "python-nanoid>=2.0.0",
{% elif uid == "ulid" %}
  "python-ulid>=3.0.0",
{% elif uid == "sparkid" %}
  "sparkid>=1.0.0",
{% endif %}
]

[project.optional-dependencies]
dev = [
  "black>=24.10.0",
  "isort>=6.0.0",
  "ruff>=0.4.1",
  "pytest>=7.4.0",
  "pytest-cov>=4.1.0",
  "coverage[toml]>=7.5.0",
  "mypy>=1.10.0",
  "flake8>=7.1.0",
  "aiosqlite>=0.21.0",
  "fakeredis>=2.22.4",
  "py-spy>=0.4.1"
]
{%- endif %}

{%- if package_manager != "poetry" %}
[tool.setuptools]
package-dir = {"" = "src"}

[tool.setuptools.packages.find]
where = ["src"]
{%- endif %}

[tool.flake8]
max-line-length = 88
extend-ignore = "E203, E501"

[tool.ruff]
exclude = [
    ".bzr",
    ".direnv",
    ".eggs",
    ".git",
    ".hg",
    ".mypy_cache",
    ".nox",
    ".pants.d",
    ".pytype",
    ".ruff_cache",
    ".svn",
    ".tox",
    ".venv",
    "__pypackages__",
    "__pycache__",
    "_build",
    "buck-out",
    "build",
    "dist",
    "venv",
    "migrations",
]
line-length = 79
src = ["src"]

[tool.ruff.lint]
select = ["E", "F"]
ignore = ["E501", "F403", "F811"]
fixable = [
    "A",
    "B",
    "C",
    "D",
    "E",
    "F",
    "G",
    "I",
    "N",
    "Q",
    "S",
    "T",
    "W",
    "ANN",
    "ARG",
    "BLE",
    "COM",
    "DJ",
    "DTZ",
    "EM",
    "ERA",
    "EXE",
    "FBT",
    "ICN",
    "INP",
    "ISC",
    "NPY",
    "PD",
    "PGH",
    "PIE",
    "PL",
    "PT",
    "PTH",
    "PYI",
    "RET",
    "RSE",
    "RUF",
    "SIM",
    "SLF",
    "TCH",
    "TID",
    "TRY",
    "UP",
    "YTT",
]
unfixable = []
dummy-variable-rgx = "^(_+|(_+[a-zA-Z0-9_]*[a-zA-Z0-9]+?))$"

[tool.ruff.lint.mccabe]
max-complexity = 10

[tool.black]
target-version = ["py312"]
line-length = 79
exclude = '''
(
  /(
      \.eggs         # exclude a few common directories in the
    | \.git          # root of the project
    | \.hg
    | \.mypy_cache
    | \.tox
    | \.venv
    | venv
    | _build
    | buck-out
    | build
    | dist
    | .tox
  )/
                     # the root of the project
)
'''

[tool.isort]
profile = "black"
multi_line_output = 3
include_trailing_comma = true
force_grid_wrap = 0
use_parentheses = true
line_length = 79
skip = ["venv"]
src_paths = ["src"]

[tool.pytest.ini_options]
addopts = "-s -vvv --cache-clear --cov=./src/app --cov-report=term-missing --cov-report=html"
pythonpath = ["src", "."]
testpaths = ["tests"]
cache_dir = "/tmp/pytest_cache"
python_files = "test_*.py *_test.py"
python_functions = "test_* *_test"
filterwarnings = [
  "ignore::RuntimeWarning",
  "ignore::UserWarning",
  "ignore::DeprecationWarning",
]
markers = [
    "integration: marks tests as integration tests",
]

[tool.pyright]
exclude = ["**/__pycache__", "**/venv/*", "**/.tox/*"]
typeCheckingMode = "off"
useLibraryCodeForTypes = true

[tool.mypy]
ignore_missing_imports = true
explicit_package_bases = true
exclude = "(^|/)(migrations)(/|$)"
disable_error_code = ["no-redef"]

[tool.coverage.report]
omit = [
  "*/tests.py",
  "*/migrations/*",
  "asgi.py",
  "wsgi.py",
  "settings.py",
  "manage.py",
]

{%- if orm == "tortoise" %}
[tool.aerich]
tortoise_orm = "{{ tortoise_orm_path }}"
location = "{{ tortoise_migrations_location }}"
src_folder = "./."
{%- endif %}

[tool.robyn-config]
design = "{{ design }}"
orm = "{{ orm }}"
package_manager = "{{ package_manager }}"
uid = "{{ uid }}"
broker = "{{ broker }}"
nosql = [{% for provider in nosql %}"{{ provider }}"{% if not loop.last %}, {% endif %}{% endfor %}]
worker = "{{ worker }}"
worker_exp_mode = {{ "true" if worker_exp_mode else "false" }}
scheduler = {{ "true" if scheduler else "false" }}

{%- if design == "ddd" %}
[tool.robyn-config.add]
domain_path = "src/app/domain"
operational_path = "src/app/operational"
presentation_path = "src/app/presentation"
database_repository_path = "src/app/infrastructure/database/repository"
database_table_path = "src/app/infrastructure/database/tables/__init__.py"
{%- elif design == "mvc" %}
[tool.robyn-config.add]
views_path = "src/app/views"
database_repository_path = "src/app/models/repository.py"
database_table_path = "src/app/models/tables/__init__.py"
{%- endif %}
