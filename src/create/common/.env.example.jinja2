# Copy this file to `.env` (ignored by git) and override values before running Docker Compose or the app locally.

# Postgres
POSTGRES_DB=database
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# Database
SETTINGS__DATABASE__DRIVER=postgresql+asyncpg
SETTINGS__DATABASE__HOST=localhost
SETTINGS__DATABASE__PORT=5432
SETTINGS__DATABASE__USER=app
SETTINGS__DATABASE__PASSWORD=app
SETTINGS__DATABASE__NAME=database

# Cache / fake mode
SETTINGS__CACHE__HOST=localhost
SETTINGS__CACHE__PORT=6379
SETTINGS__CACHE__DB=0
SETTINGS__CACHE__USE_FAKE=false
{% if broker == "redis" %}

# Broker / Redis
SETTINGS__BROKER__HOST=localhost
SETTINGS__BROKER__PORT=6380
SETTINGS__BROKER__DB=1
SETTINGS__BROKER__TOPIC_PREFIX=app
{% elif broker == "rabbitmq" %}

# Broker / RabbitMQ
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app
SETTINGS__BROKER__HOST=localhost
SETTINGS__BROKER__PORT=5672
SETTINGS__BROKER__USER=app
SETTINGS__BROKER__PASSWORD=app
SETTINGS__BROKER__VIRTUAL_HOST=/
SETTINGS__BROKER__EXCHANGE=app.events
{% elif broker == "kafka" %}

# Broker / Kafka
SETTINGS__BROKER__BOOTSTRAP_SERVERS=localhost:29092
SETTINGS__BROKER__CLIENT_ID=robyn-app
SETTINGS__BROKER__GROUP_ID=robyn-app
SETTINGS__BROKER__TOPIC_PREFIX=app
{% endif %}
{% if worker != "none" %}

# Worker / {{ worker|capitalize }}
SETTINGS__WORKER__QUEUE=app.workers
{% if worker == "celery" %}
{% if worker_backend == "rabbitmq" %}
SETTINGS__WORKER__BROKER_URL=amqp://app:app@localhost:5672//
{% elif worker_backend == "kafka" %}
SETTINGS__WORKER__BROKER_URL=confluentkafka://localhost:29092
{% elif worker_redis_service == "redis-broker" %}
SETTINGS__WORKER__BROKER_URL=redis://localhost:6380/{{ worker_redis_db }}
{% else %}
SETTINGS__WORKER__BROKER_URL=redis://localhost:6379/{{ worker_redis_db }}
{% endif %}
{% if worker_result_redis_service == "redis-broker" %}
SETTINGS__WORKER__RESULT_BACKEND=redis://localhost:6380/{{ worker_result_redis_db }}
{% else %}
SETTINGS__WORKER__RESULT_BACKEND=redis://localhost:6379/{{ worker_result_redis_db }}
{% endif %}
{% elif worker == "dramatiq" %}
SETTINGS__WORKER__BACKEND={{ worker_backend }}
{% if worker_backend == "rabbitmq" %}
SETTINGS__WORKER__RABBITMQ_URL=amqp://app:app@localhost:5672//
{% elif worker_redis_service == "redis-broker" %}
SETTINGS__WORKER__REDIS_URL=redis://localhost:6380/{{ worker_redis_db }}
{% else %}
SETTINGS__WORKER__REDIS_URL=redis://localhost:6379/{{ worker_redis_db }}
{% endif %}
{% elif worker_redis_service == "redis-broker" %}
SETTINGS__WORKER__REDIS_URL=redis://localhost:6380/{{ worker_redis_db }}
{% else %}
SETTINGS__WORKER__REDIS_URL=redis://localhost:6379/{{ worker_redis_db }}
{% endif %}
{% endif %}
{% if "mongodb" in nosql %}

# NoSQL / MongoDB
MONGO_INITDB_ROOT_USERNAME=app
MONGO_INITDB_ROOT_PASSWORD=app
SETTINGS__NOSQL__MONGODB__HOST=localhost
SETTINGS__NOSQL__MONGODB__PORT=27017
SETTINGS__NOSQL__MONGODB__USER=app
SETTINGS__NOSQL__MONGODB__PASSWORD=app
SETTINGS__NOSQL__MONGODB__DATABASE=app
SETTINGS__NOSQL__MONGODB__AUTH_SOURCE=admin
{% endif %}
{% if "neo4j" in nosql %}

# NoSQL / Neo4j
NEO4J_AUTH=neo4j/app-password
SETTINGS__NOSQL__NEO4J__URI=neo4j://localhost:7687
SETTINGS__NOSQL__NEO4J__USER=neo4j
SETTINGS__NOSQL__NEO4J__PASSWORD=app-password
SETTINGS__NOSQL__NEO4J__DATABASE=neo4j
{% endif %}

# Mail
SETTINGS__MAILING__HOST=localhost
SETTINGS__MAILING__PORT=1025
SETTINGS__MAILING__SENDER_EMAIL=no-reply@example.com
SETTINGS__MAILING__SENDER_NAME="Robyn App"

# Runtime
SETTINGS__DEBUG=false
LOGURU_LEVEL=WARNING

# Logging
SETTINGS__LOGGING__FILE=app
