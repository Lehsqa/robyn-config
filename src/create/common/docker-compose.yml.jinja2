version: "3.9"

services:
  postgres:
    image: postgres:16
    container_name: database
    restart: unless-stopped
    env_file:
      - .env
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U app -d database"]
      interval: 10s
      timeout: 5s
      retries: 5
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data

  valkey:
    image: valkey/valkey:7.2-alpine
    container_name: cache
    restart: unless-stopped
    command: ["valkey-server", "--save", "", "--appendonly", "no"]
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% if broker == "redis" %}

  redis-broker:
    image: redis:7.2-alpine
    container_name: broker
    restart: unless-stopped
    command: ["redis-server", "--save", "", "--appendonly", "no"]
    ports:
      - "6380:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% elif broker == "rabbitmq" %}

  rabbitmq:
    image: rabbitmq:3.13-management-alpine
    container_name: broker
    restart: unless-stopped
    ports:
      - "5672:5672"
      - "15672:15672"
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
{% elif broker == "kafka" %}

  kafka:
    image: apache/kafka:4.3.0
    container_name: broker
    restart: unless-stopped
    environment:
      KAFKA_NODE_ID: "1"
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:9093
      KAFKA_LISTENERS: PLAINTEXT://:9092,CONTROLLER://:9093,EXTERNAL://:29092
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka:9092,EXTERNAL://localhost:29092
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: PLAINTEXT:PLAINTEXT,CONTROLLER:PLAINTEXT,EXTERNAL:PLAINTEXT
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER
      CLUSTER_ID: 4L6g3nShT-eMCtK--X86sw
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: "1"
      KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS: "0"
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: "1"
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: "1"
      KAFKA_SHARE_COORDINATOR_STATE_TOPIC_REPLICATION_FACTOR: "1"
      KAFKA_SHARE_COORDINATOR_STATE_TOPIC_MIN_ISR: "1"
      KAFKA_LOG_DIRS: /tmp/kraft-combined-logs
    ports:
      - "29092:29092"
{% endif %}
{% if "mongodb" in nosql %}

  mongodb:
    image: mongo:7.0
    container_name: mongodb
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "27017:27017"
    volumes:
      - mongodb-data:/data/db
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          mongosh --quiet
          --username "$${MONGO_INITDB_ROOT_USERNAME}"
          --password "$${MONGO_INITDB_ROOT_PASSWORD}"
          --authenticationDatabase admin
          --eval "db.adminCommand('ping').ok"
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}
{% if "neo4j" in nosql %}

  neo4j:
    image: neo4j:2026.04.0
    container_name: neo4j
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "7474:7474"
      - "7687:7687"
    volumes:
      - neo4j-data:/data
    healthcheck:
      test:
        - CMD-SHELL
        - >-
          cypher-shell -u neo4j -p "$${NEO4J_AUTH#*/}" "RETURN 1"
      interval: 10s
      timeout: 5s
      retries: 10
{% endif %}

  mailhog:
    image: mailhog/mailhog:v1.0.1
    container_name: mailing
    restart: unless-stopped
    ports:
      - "1025:1025"
      - "8025:8025"

  app:
    build:
      context: .
      dockerfile: compose/app/Dockerfile
      target: prod
      platforms:
        - linux/amd64
    container_name: app
    env_file:
      - .env
    environment:
      SETTINGS__DATABASE__HOST: postgres
      SETTINGS__CACHE__HOST: valkey
      SETTINGS__MAILING__HOST: mailhog
{% if broker == "redis" %}
      SETTINGS__BROKER__HOST: redis-broker
      SETTINGS__BROKER__PORT: 6379
{% elif broker == "rabbitmq" %}
      SETTINGS__BROKER__HOST: rabbitmq
      SETTINGS__BROKER__PORT: 5672
{% elif broker == "kafka" %}
      SETTINGS__BROKER__BOOTSTRAP_SERVERS: kafka:9092
{% endif %}
{% if "mongodb" in nosql %}
      SETTINGS__NOSQL__MONGODB__HOST: mongodb
{% endif %}
{% if "neo4j" in nosql %}
      SETTINGS__NOSQL__NEO4J__URI: neo4j://neo4j:7687
{% endif %}
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      valkey:
        condition: service_healthy
      mailhog:
        condition: service_started
{% if broker == "redis" %}
      redis-broker:
        condition: service_healthy
{% elif broker == "rabbitmq" %}
      rabbitmq:
        condition: service_healthy
{% elif broker == "kafka" %}
      kafka:
        condition: service_started
{% endif %}
{% if "mongodb" in nosql %}
      mongodb:
        condition: service_healthy
{% endif %}
{% if "neo4j" in nosql %}
      neo4j:
        condition: service_healthy
{% endif %}
    ports:
      - "8000:8000"
    volumes:
      - app-logs:/app/logs
      - ./src/app:/app/src/app

volumes:
  postgres-data:
{% if "mongodb" in nosql %}
  mongodb-data:
{% endif %}
{% if "neo4j" in nosql %}
  neo4j-data:
{% endif %}
  app-logs:
